# Copy this file to xdr-soar-infra/config/platform.env and replace the values
# with the real deployment settings for your environment.
XDR_SOAR_BASE_DOMAIN=soar.example.com
XDR_SOAR_INGRESS_CLASS=nginx
XDR_SOAR_CERT_MANAGER_CLUSTER_ISSUER=letsencrypt-prod
XDR_SOAR_ACME_EMAIL=platform-ops@example.com
XDR_SOAR_ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory
XDR_SOAR_TLS_SECRET_NAME=xdr-soar-platform-tls
MQTT_BROKER_HOST=mqtt.soar.example.com
MQTT_BROKER_PORT=8883
MQTT_TOPIC=/agent/update
UPDATE_API_BASE_URL=https://api.soar.example.com/v1/firmware
